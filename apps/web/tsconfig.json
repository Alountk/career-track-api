{
  "extends": "astro/tsconfigs/strictest",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@core/*": ["src/core/*"],
      "@infrastructure/*": ["src/infrastructure/*"],
      "@components/*": ["src/infrastructure/components/*"],
      "@pages/*": ["src/pages/*"],
      "@test/*": ["test/*"]
    },
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  }
}
