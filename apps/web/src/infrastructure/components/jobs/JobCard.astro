---
import type { JobApplication } from '../../../core/domain/entities/job-application.entity';

interface Props {
  job: JobApplication;
}

const { job } = Astro.props;

// Diccionary of colors for states
const statusColors = {
  PENDING:
    'from-slate-500/20 to-slate-500/10 text-slate-400 border-slate-500/50',
  APPLIED: 'from-blue-500/20 to-blue-500/10 text-blue-400 border-blue-500/50',
  INTERVIEWING:
    'from-purple-500/20 to-purple-500/10 text-purple-400 border-purple-500/50',
  OFFER:
    'from-emerald-500/20 to-emerald-500/10 text-emerald-400 border-emerald-500/50',
  REJECTED: 'from-rose-500/20 to-rose-500/10 text-rose-400 border-rose-500/50',
};

const statusLabel = {
  PENDING: 'Pendiente',
  APPLIED: 'Enviada',
  INTERVIEWING: 'Entrevista',
  OFFER: '¡Oferta!',
  REJECTED: 'Rechazado / Rechazada',
};
---

<article
  class="group relative bg-[var(--bg-surface)] border border-white/5 rounded-2xl p-6 transition-all duration-300 hover:scale-[1.02] hover:shadow-2xl hover:shadow-nebula-primary/10 overflow-hidden"
>
  <!-- Glow Effect -->
  <div
    class="absolute -inset-px bg-gradient-to-r from-nebula-primary/20 to-nebula-secondary/20 opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-2xl blur-sm -z-10"
  >
  </div>

  <!-- Content Container -->
  <div class="relative z-10">
    <div class="flex justify-between items-start mb-4">
      <div>
        <h3
          class="text-xl font-bold text-white group-hover:text-nebula-primary transition-colors"
        >
          {job.position}
        </h3>
        <p class="text-slate-400 font-medium">{job.company}</p>
      </div>

      <!-- State of Badge -->
      <span
        class={`px-3 py-1 rounded-full text-xs font-bold border bg-gradient-to-br ${statusColors[job.status]}`}
        >{statusLabel[job.status]}
      </span>
    </div>

    <div class="space-y-3">
      {
        job.salaryRange && (
          <div class="flex items-center text-sm text-slate-300">
            <span class="mr-2 opacity-50">💰</span>
            {job.salaryRange}
          </div>
        )
      }

      <div class="flex items-center text-sm text-slate-400 italic">
        <span class="mr-2 opacity-50">📅</span>
        {job.createdAt.toLocaleDateString()}
      </div>
    </div>

    {
      job.url && (
        <a
          href={job.url}
          target="_blank"
          class="mt-6 block w-full py-2.5 text-center rounded-xl bg-white/5 hover:bg-white/10 text-sm font-semibold text-white transition-all border border-white/5"
        >
          Ver oferta ↗
        </a>
      )
    }
  </div>
</article>
