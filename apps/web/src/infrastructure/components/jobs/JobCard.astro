---
import type { JobApplication } from '../../../core/domain/entities/job-application.entity';

interface Props {
  job: JobApplication;
}

const { job } = Astro.props;

const statusColors = {
  PENDING:
    'from-slate-500/10 to-transparent text-slate-400 border-slate-500/20',
  APPLIED: 'from-blue-500/10 to-transparent text-blue-300 border-blue-500/20',
  INTERVIEWING:
    'from-purple-500/10 to-transparent text-purple-300 border-purple-500/20',
  OFFER:
    'from-emerald-500/10 to-transparent text-emerald-300 border-emerald-500/20',
  REJECTED: 'from-rose-500/10 to-transparent text-rose-300 border-rose-500/20',
};

const statusLabel = {
  PENDING: 'Pendiente',
  APPLIED: 'Enviada',
  INTERVIEWING: 'Entrevista',
  OFFER: '¡Oferta!',
  REJECTED: 'Rechazado',
};
---

<article
  class="glass group relative p-6 rounded-[2rem] transition-all duration-500 hover:-translate-y-1 hover:shadow-2xl hover:shadow-nebula-primary/5 active:scale-[0.98]"
>
  <!-- Interactive Gradient Glow -->
  <div
    class="absolute -inset-2 bg-gradient-to-br from-nebula-primary/10 via-transparent to-nebula-secondary/10 opacity-0 group-hover:opacity-100 transition-opacity duration-700 blur-2xl -z-10"
  >
  </div>

  <div class="relative z-10">
    <div class="flex justify-between items-start mb-6">
      <div class="space-y-1">
        <h3
          class="text-3xl font-medium leading-tight text-white/90 group-hover:text-white transition-colors duration-300"
        >
          {job.position}
        </h3>
        <p
          class="text-sm font-semibold tracking-widest uppercase text-slate-500/80"
        >
          {job.company}
        </p>
      </div>

      <span
        class={`px-4 py-1.5 rounded-full text-[10px] uppercase tracking-widest font-black border bg-gradient-to-br shadow-sm ${statusColors[job.status] || statusColors.PENDING}`}
      >
        {statusLabel[job.status] || 'Pendiente'}
      </span>
    </div>

    <div class="grid grid-cols-2 gap-4 mt-8">
      <div class="p-4 rounded-2xl bg-white/[0.02] border border-white/[0.03]">
        <span class="block text-[10px] uppercase text-slate-500 mb-1 font-bold"
          >Salario</span
        >
        <span class="text-sm text-slate-300 font-medium"
          >{job.salaryRange || 'No especificado'}</span
        >
      </div>
      <div class="p-4 rounded-2xl bg-white/[0.02] border border-white/[0.03]">
        <span class="block text-[10px] uppercase text-slate-500 mb-1 font-bold"
          >Fecha</span
        >
        <span class="text-sm text-slate-300 font-medium"
          >{new Date(job.createdAt).toLocaleDateString()}</span
        >
      </div>
    </div>

    {
      job.url && (
        <a
          href={job.url}
          target="_blank"
          class="mt-6 flex items-center justify-center gap-2 w-full py-4 text-xs font-bold uppercase tracking-widest text-white/70 hover:text-white bg-white/[0.03] hover:bg-white/[0.07] rounded-2xl transition-all border border-white/[0.05] group/btn"
        >
          Explorar Oferta
          <span class="transform group-hover/btn:translate-x-1 group-hover/btn:-translate-y-1 transition-transform">
            ↗
          </span>
        </a>
      )
    }
  </div>
</article>
