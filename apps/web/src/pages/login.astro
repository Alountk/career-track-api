---
const token = Astro.cookies.get('auth_token');
if (token) {
  return Astro.redirect('/');
}
import MainLayout from '@infrastructure/components/layout/MainLayout.astro';
import { LoginForm } from '@infrastructure/components/auth/LoginForm';
---

<MainLayout title="Login | Career Track">
  <div class="min-h-[80vh] flex flex-col items-center justify-center">
    <a
      href="/"
      class="mb-10 text-3xl font-black text-transparent bg-clip-text bg-gradient-to-r from-nebula-primary to-nebula-secondary"
    >
      Career Track
    </a>

    <LoginForm client:load />
  </div>
</MainLayout>
