---
import MainLayout from '../infrastructure/components/layout/MainLayout.astro';
import JobCard from '../infrastructure/components/jobs/JobCard.astro';
import type { JobApplication } from '@core/domain/entities/job-application.entity';
import { FetchJobApplicationRepository } from '@infrastructure/adapters/job-application/fetch-job-application.repository';
import { GetAllJobApplicationsUseCase } from '@core/application/use-cases/jobs/get-all-job-applications.use-case';

const token = Astro.cookies.get('auth_token');
if (!token) {
  return Astro.redirect('/login');
}

const jobRepo = new FetchJobApplicationRepository(token.value);
const getAllJobs = new GetAllJobApplicationsUseCase(jobRepo);

let jobs: JobApplication[] = [];
try {
  jobs = await getAllJobs.execute();
} catch (error) {
  console.error(error);
}

---

<MainLayout title="Dashboard | Career Track">
  <div class="py-12">
    <header class="mb-12">
      <h1
        class="text-5xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-nebula-primary to-nebula-secondary"
      >
        Career Track
      </h1>
      <p class="mt-2 text-slate-400 font-medium tracking-wide">
        Tus procesos de selección, bajo control.
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {jobs.length > 0 ? (
        jobs.map(job => <JobCard job={job} />)
      ) : (
        <div class="col-span-full py-20 text-center border-2 border-dashed border-white/5 rounded-3xl">
          <p class="text-slate-500 font-medium">Aún no has añadido ninguna aplicación.</p>
        </div>
      )}
    </div>
  </div>
</MainLayout>
