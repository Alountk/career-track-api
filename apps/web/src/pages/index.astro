---
const token = Astro.cookies.get('auth_token');
if (!token) {
  return Astro.redirect('/login');
}
import MainLayout from '../infrastructure/components/layout/MainLayout.astro';
import JobCard from '../infrastructure/components/jobs/JobCard.astro';
import type { JobApplication } from '@core/domain/entities/job-application.entity';

// Harcoded test object
const mockJobs = [
  {
    id: '1',
    company: 'Google',
    position: 'Senior Frontend Developer',
    status: 'INTERVIEWING',
    userId: 'u1',
    salaryRange: '120k - 150k €',
    createdAt: new Date(),
    updatedAt: new Date(),
  },
  {
    id: '2',
    company: 'Stripe',
    position: 'Product Designer',
    status: 'OFFER',
    userId: 'u1',
    url: 'https://stripe.com/jobs',
    createdAt: new Date(),
    updatedAt: new Date(),
  },
];
---

<MainLayout title="Dashboard | Career Track">
  <div class="py-12">
    <header class="mb-12">
      <h1
        class="text-5xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-nebula-primary to-nebula-secondary"
      >
        Career Track
      </h1>
      <p class="mt-2 text-slate-400 font-medium tracking-wide">
        Tus procesos de selección, bajo control.
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {mockJobs.map((job) => <JobCard job={job as unknown as JobApplication} />)}
    </div>
  </div>
</MainLayout>
