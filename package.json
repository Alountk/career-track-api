{
  "name": "career-track",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "devDependencies": {
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.0"
  },
  "scripts": {
    "dev": "concurrently \"pnpm --filter career-track-api start:dev\" \"pnpm --filter @career-track/web dev\"",
    "prepare": "husky",
    "test": "pnpm -r test"
  },
  "lint-staged": {
    "apps/api/**/*.ts": [
      "pnpm --filter career-track-api run lint"
    ],
    "apps/web/**/*.{ts,tsx,astro}": [
      "pnpm --filter @career-track/web run lint"
    ]
  }
}