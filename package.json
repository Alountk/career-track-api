{
  "name": "career-track",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.3.0"
  },
  "scripts": {
    "prepare": "husky"
  },
  "lint-staged": {
    "apps/api/**/*.ts": [
      "pnpm run lint --filter career-track-api"
    ],
    "apps/web/**/*.{ts,tsx,astro}": [
      "pnpm run lint --filter @career-track/web"
    ]
  }
}